{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Porttera",
  "description": "Guides and reference for the Porttera apps — Wholesale, Product Customizer, and Bundles.",
  "colors": {
    "primary": "#111111",
    "light": "#f9f9f5",
    "dark": "#111111"
  },
  "appearance": {
    "default": "dark"
  },
  "fonts": {
    "heading": {
      "family": "Cormorant Garamond",
      "weight": 500
    },
    "body": {
      "family": "Inter"
    }
  },
  "background": {
    "color": {
      "light": "#f9f9f5",
      "dark": "#111111"
    },
    "decoration": "grid"
  },
  "styling": {
    "codeblocks": "dark"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Get started",
        "icon": "rocket",
        "groups": [
          { "group": "Welcome", "pages": ["index", "install"] },
          { "group": "Resources", "pages": ["faq", "changelog"] }
        ]
      },
      {
        "tab": "Wholesale",
        "icon": "tags",
        "groups": [
          { "group": "Wholesale", "pages": ["wholesale/overview", "wholesale/quickstart", "wholesale/features", "wholesale/settings", "wholesale/developer", "wholesale/troubleshooting"] }
        ]
      },
      {
        "tab": "Product Customizer",
        "icon": "wand-magic-sparkles",
        "groups": [
          { "group": "Product Customizer", "pages": ["customizer/overview", "customizer/quickstart", "customizer/features", "customizer/settings", "customizer/developer", "customizer/troubleshooting"] }
        ]
      },
      {
        "tab": "Bundles",
        "icon": "boxes-stacked",
        "groups": [
          { "group": "Bundles", "pages": ["bundles/overview", "bundles/quickstart", "bundles/features", "bundles/settings", "bundles/developer", "bundles/troubleshooting"] }
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      { "label": "Support", "href": "https://porttera.com/pages/contact" }
    ],
    "primary": { "type": "button", "label": "porttera.com", "href": "https://porttera.com" }
  },
  "footer": {
    "socials": { "website": "https://porttera.com" }
  }
}
