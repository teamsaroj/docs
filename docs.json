{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Porttera Bundles",
  "description": "Install, configure, customize, and uninstall Porttera Bundles.",
  "colors": {
    "primary": "#111111",
    "light": "#f9f9f5",
    "dark": "#111111"
  },
  "appearance": {
