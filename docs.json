  "styling": {
    "codeblocks": "dark"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navigation": {
    "groups": [
      { "group": "Welcome", "pages": ["index", "faq", "changelog"] },
      {
        "group": "Bundles",
        "pages": [
          "bundles/overview",
          "bundles/installation",
          "bundles/configuration",
          "bundles/customization",
          "bundles/features",
          "bundles/how-it-works",
          "bundles/uninstalling",
          "bundles/troubleshooting"
        ]
      }
    ]
