  "navbar": {
    "links": [
      { "label": "Support", "href": "https://porttera.com/pages/contact" }
    ],
    "primary": { "type": "button", "label": "porttera.com", "href": "https://porttera.com" }
  },
  "footer": {
    "socials": { "website": "https://porttera.com" }
